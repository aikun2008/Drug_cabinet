# 环境配置示例文件
# 复制此文件为 .env 并填入实际配置值

# ========================== 服务器配置 ==========================
# 域名配置
DOMAIN_NAME=your-domain.com

# ========================== MQTT (EMQX) 配置 ==========================
EMQX_BROKER_IP=your-mqtt-server-ip
EMQX_BROKER_PORT=1883
EMQX_USERNAME=your-mqtt-username
EMQX_PASSWORD=your-mqtt-password
EMQX_CLIENT_ID=server_windows

# ========================== Redis 配置 ==========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
REDIS_DEFAULT_TTL=3600

# ========================== 数据库配置 ==========================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-database-password
MYSQL_DATABASE_1=web
MYSQL_DATABASE_2=history

# ========================== JWT 配置 ==========================
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# ========================== EMQX API 配置 ==========================
EMQX_DASHBOARD_USERNAME=admin
EMQX_DASHBOARD_PASSWORD=your-emqx-dashboard-password
EMQX_API_KEY=your-emqx-api-key
EMQX_API_SECRET=your-emqx-api-secret

# ========================== 小程序配置 ==========================
# 小程序后端 API 地址
MINI_PROGRAM_API_BASE_URL=https://your-domain.com/api
# 小程序图片资源 CDN 地址
MINI_PROGRAM_IMAGE_CDN=https://your-domain.com/static/picture

# ========================== ESP32 固件配置 ==========================
# MQTT 服务器地址
ESP32_MQTT_ADDRESS=mqtt://your-mqtt-server-ip
ESP32_MQTT_PORT=1883
ESP32_MQTT_CLIENT_ID=cabinet_002
ESP32_MQTT_USERNAME=your-mqtt-username
ESP32_MQTT_PASSWORD=your-mqtt-password
