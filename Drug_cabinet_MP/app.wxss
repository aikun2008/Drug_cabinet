/* app.wxss */
.container {
  padding: 20rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  width: 100%;
  height: 80rpx;
  background-color: #1976D2;
  color: white;
  border-radius: 40rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.btn:active {
  opacity: 0.8;
}

/* 卡片样式 */
.card {
  background-color: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 标题样式 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin: 20rpx 0;
}

/* 列表项样式 */
.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.list-item:last-child {
  border-bottom: none;
}

/* 输入框样式 */
.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  margin: 20rpx 0;
  box-sizing: border-box;
  font-size: 32rpx;
}

/* 错误提示样式 */
.error {
  color: #f44336;
  font-size: 28rpx;
  margin: 10rpx 0;
}

/* 加载样式 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
}

/* 空状态样式 */
.empty {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 32rpx;
}

/* 状态标签样式 */
.status-tag {
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: white;
}

.status-available {
  background-color: #4CAF50;
}

.status-unavailable {
  background-color: #f44336;
}

.status-warning {
  background-color: #FF9800;
}

/* 底部标签栏样式 */
/* 调整tabBar整体样式 */
page {
  --tab-bar-height: 120rpx;
}

/* 调整tabBar项样式 */
.tabbar {
  height: var(--tab-bar-height) !important;
}

/* 调整tabBar文本样式 */
.tabbar-item {
  height: var(--tab-bar-height) !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  align-items: center !important;
}

.tabbar-item__text {
  font-size: 60rpx !important;
  margin-top: 0 !important;
  font-weight: 500 !important;
}

/* 兼容旧版选择器 */
.wx-tabbar {
  height: 120rpx !important;
}

.wx-tabbar-item {
  height: 120rpx !important;
  display: flex !important;
  flex-direction: column !important;
  justify-content: center !important;
  align-items: center !important;
}

.wx-tabbar-item__text {
  font-size: 60rpx !important;
  margin-top: 0 !important;
  font-weight: 500 !important;
}