/* profile.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

/* 用户信息卡片 */
.user-info-card {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #1976D2 0%, #1E88E5 100%);
  color: white;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 30rpx;
}

.role-icon {
  font-size: 60rpx;
  color: white;
}


.user-details {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.user-role {
  display: block;
  font-size: 32rpx;
  margin-bottom: 10rpx;
  opacity: 0.9;
}

.user-department {
  display: block;
  font-size: 28rpx;
  opacity: 0.8;
}

/* 功能列表 */
.menu-item {
  display: flex;
  align-items: center;
  padding: 25rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  transition: all 0.3s;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-item:active {
  background-color: #f5f5f5;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 30rpx;
}

.menu-text {
  flex: 1;
  font-size: 32rpx;
  color: #333;
}

.logout-text {
  color: #f44336;
}

.menu-arrow {
  font-size: 36rpx;
  color: #999;
}

/* 系统信息 */
.system-info {
  text-align: center;
  margin-top: 50rpx;
  padding: 20rpx;
}

.version-text {
  display: block;
  font-size: 28rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.copyright-text {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 确认弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.modal-content {
  background-color: white;
  width: 90%;
  max-width: 600rpx;
  border-radius: 20rpx;
  overflow: hidden;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.close-btn {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.modal-body {
  flex: 1;
  padding: 40rpx 30rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  overflow-y: auto;
}

.modal-footer {
  display: flex;
  padding: 20rpx 30rpx 30rpx;
  gap: 20rpx;
}

.btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin: 0;
}

.btn-primary {
  background-color: #1976D2;
  color: white;
}

.btn-secondary {
  background-color: #f5f5f5;
  color: #333;
}

.btn-danger {
  background-color: #f44336;
  color: white;
}

.btn-success {
  background-color: #4CAF50;
  color: white;
}

/* 学生管理模态框样式 */
.modal-content {
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-body {
  flex: 1;
  overflow-y: auto;
  text-align: center;
}

/* 学生列表样式 */
.students-list {
  margin-top: 10rpx;
}

.student-item {
  display: flex;
  align-items: center;
  padding: 10rpx;
  border-bottom: 1rpx solid #f0f0f0;
  justify-content: space-between;
}

.student-item button {
  flex-shrink: 0 !important;
  width: 35rpx !important;
  min-width: 35rpx !important;
  max-width: 35rpx !important;
  height: 20rpx !important;
  line-height: 20rpx !important;
  padding: 2rpx 6rpx !important;
  font-size: 12rpx !important;
  margin: 0 !important;
  flex: none !important;
}

.student-info {
  flex: 1;
  text-align: left;
  margin-right: 10rpx;
}

.student-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
  display: block;
}

.student-id {
  font-size: 18rpx;
  color: #999;
}

/* 解绑按钮样式 */
.unbind-btn {
  background-color: #f44336;
  color: white;
  border-radius: 8rpx;
  padding: 4rpx 12rpx;
  font-size: 14rpx;
  text-align: center;
  width: 60rpx;
  min-width: 60rpx;
  max-width: 60rpx;
  height: 28rpx;
  line-height: 28rpx;
  margin: 0;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  cursor: pointer;
}

/* 加载和错误状态 */
.loading-container,
.empty-container,
.error-container {
  padding: 40rpx 0;
}

.error-text {
  color: #f44336;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.empty-container text {
  color: #999;
  font-size: 24rpx;
}

/* 学生选择模态框样式 */
.student-select-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.student-select-content.modal-content {
  background-color: white;
  width: 90%;
  max-width: 600rpx;
  border-radius: 20rpx;
  overflow: hidden;
  max-height: 85vh;
  display: flex;
  flex-direction: column;
}

.student-select-body {
  flex: 1;
  overflow-y: auto;
  padding: 20rpx 30rpx;
}

.student-select-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.student-select-item:last-child {
  border-bottom: none;
}

.student-select-info {
  flex: 1;
  text-align: left;
  margin-right: 10rpx;
}

.student-select-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
  display: block;
}

.student-select-id {
  font-size: 18rpx;
  color: #999;
}

.select-checkbox {
  font-size: 32rpx;
  color: #1976D2;
}

/* 添加学生按钮样式 */
.add-student-btn {
  background-color: #4CAF50;
  color: white;
  border: none;
  border-radius: 40rpx;
  padding: 15rpx;
  font-size: 24rpx;
  width: 100%;
  margin-top: 20rpx;
  text-align: center;
}

/* 购物车悬浮按钮 */
.cart-float-button {
  position: fixed;
  bottom: 30rpx;
  right: 30rpx;
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #1976D2;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 10rpx rgba(0, 0, 0, 0.2);
  z-index: 1000;
}

.cart-icon {
  font-size: 40rpx;
  color: white;
}

.cart-float-button:active {
  transform: scale(0.95);
  opacity: 0.8;
}