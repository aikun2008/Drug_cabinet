/* login.wxss */
.container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100vh;
  background-color: #f5f5f5;
}

.login-form {
  width: 90%;
  max-width: 400rpx;
  background-color: white;
  padding: 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.logo {
  text-align: center;
  margin-bottom: 40rpx;
}

.logo-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #1976D2;
}

.form-item {
  margin: 30rpx 0;
}

.label {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 10rpx;
  font-weight: 500;
}

.input {
  width: 100%;
  height: 80rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  font-size: 32rpx;
}

.input:focus {
  border-color: #1976D2;
}

.btn {
  width: 100%;
  height: 80rpx;
  background-color: #1976D2;
  color: white;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin-top: 40rpx;
}

.error {
  color: #f44336;
  font-size: 28rpx;
  margin: 20rpx 0;
  text-align: center;
}

/* 角色说明 */
.role-info {
  margin-top: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e0e0e0;
}

.role-info-text {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  text-align: center;
}

.role-list {
  display: flex;
  justify-content: space-around;
  margin-top: 10rpx;
}

.role-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 15rpx;
}

.role-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.role-name {
  font-size: 24rpx;
  color: #666;
}
