<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">申请查询</text>
  </view>

  <!-- 标签栏 -->
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'pending_approval' ? 'active' : ''}}" bindtap="switchTab" data-tab="pending_approval">
      <text>待审核</text>
    </view>
    <view class="tab-item {{activeTab === 'completed' ? 'active' : ''}}" bindtap="switchTab" data-tab="completed">
      <text>已通过</text>
    </view>
    <view class="tab-item {{activeTab === 'cancelled' ? 'active' : ''}}" bindtap="switchTab" data-tab="cancelled">
      <text>已驳回</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 申请记录列表 -->
  <view wx:else>
    <view wx:if="{{filteredApplications.length > 0}}" class="application-list">
      <view class="application-item" wx:for="{{filteredApplications}}" wx:key="id">
        <view class="application-header">
          <text class="drug-name">{{item.drug_name}}</text>
          <text class="status" style="color: {{item.status === 'pending_approval' ? '#FF9800' : (item.status === 'approved' ? '#4CAF50' : (item.status === 'rejected' ? '#F44336' : '#9E9E9E'))}}">
            {{formatStatus(item.status)}}
          </text>
        </view>
        <view class="application-body">
          <view class="info-item">
            <text class="label">规格：</text>
            <text class="value">{{item.specification}}</text>
          </view>
          <view class="info-item">
            <text class="label">药品编码：</text>
            <text class="value">{{item.medicine_code}}</text>
          </view>
          <view class="info-item">
            <text class="label">申请时间：</text>
            <text class="value">{{formatTime(item.reservation_time)}}</text>
          </view>
          <view class="info-item" wx:if="{{item.updated_at}}">
            <text class="label">更新时间：</text>
            <text class="value">{{formatTime(item.updated_at)}}</text>
          </view>
          <view class="info-item" wx:if="{{item.remark}}">
            <text class="label">备注：</text>
            <text class="value">{{item.remark}}</text>
          </view>
        </view>
      </view>
    </view>
    <view wx:else class="empty">
      <text>暂无申请记录</text>
    </view>
  </view>
</view>
