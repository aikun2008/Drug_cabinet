/* drugRecords.wxss */
.container {
  padding: 20rpx;
  background-color: #f5f5f5;
  min-height: 100vh;
}

.header {
  margin-bottom: 30rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
}

/* 标签栏 */
.tab-bar {
  display: flex;
  background-color: white;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  border-radius: 8rpx;
  margin: 0 5rpx;
}

.tab-item.active {
  background-color: #1976D2;
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
}

.tab-item.active .tab-text {
  color: white;
  font-weight: bold;
}

.content {
  background-color: white;
  border-radius: 12rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.record-list {
  margin-top: 10rpx;
}

.record-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.record-item:last-child {
  border-bottom: none;
}

.record-info {
  flex: 1;
  margin-right: 20rpx;
}

.record-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 10rpx;
  display: block;
}

.record-spec {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 5rpx;
  display: block;
}

.record-time {
  font-size: 26rpx;
  color: #999999;
  display: block;
}

.record-status {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999999;
  font-size: 30rpx;
}